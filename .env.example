# ============================================
# SISTEMA DE NOTAS - VARIABLES DE ENTORNO
# ============================================
# Copia este archivo a .env y ajusta los valores:
#   cp .env.example .env

# --- Base de Datos (PostgreSQL) ---
DB_HOST=localhost
DB_NAME=notas_db
DB_USER=postgres
DB_PASSWORD=1234

# --- Inteligencia Artificial ---
# Opción 1: Google Gemini (por defecto)
# 1. Obtén tu API key gratuita en https://aistudio.google.com/apikey
# 2. Asigna la clave aquí:
IA_API_KEY=tu-api-key-de-google-gemini
# URL y modelo ya tienen valores por defecto para Gemini:
# IA_API_URL=https://generativelanguage.googleapis.com/v1beta/openai/chat/completions
# IA_MODEL=gemini-2.0-flash

# Opción 2: Ollama (local y gratuito)
# 1. Instala Ollama: https://ollama.ai
# 2. Descarga un modelo: ollama pull llama3
# 3. Inicia Ollama: ollama serve
# 4. Descomenta estas líneas:
# IA_API_URL=http://localhost:11434/v1/chat/completions
# IA_API_KEY=
# IA_MODEL=llama3

# Opción 3: OpenAI
# IA_API_URL=https://api.openai.com/v1/chat/completions
# IA_API_KEY=sk-tu-api-key-de-openai
# IA_MODEL=gpt-4o-mini
